---
import BaseLayout from "../layouts/baselayout.astro";
import QueryPosts from "../components/query-posts.astro";

import { CONFIG } from "@config";

import Home from "../data/home.mdx"
---

<BaseLayout>
  
  <Home />
  <div class="mt-xl">
    <a href="/character-generator/">Character Generator</a>
    <QueryPosts nbPosts={CONFIG.HOME_NB_POSTS} hasCover={CONFIG.POST_COVER} sectionHeaderContentClass="duo-lg"/>
  </div>
</BaseLayout>
